# Project URL from Supabase Dashboard → Settings → API (must resolve in the browser).
# Wrong URL causes "Failed to fetch" / ERR_NAME_NOT_RESOLVED on the home catalog.
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_CREATOR_EMAIL="you@example.com"

# Optional storage (see README / supabase/*.sql)
# NEXT_PUBLIC_SUPABASE_VIDEO_BUCKET=lesson-videos
# NEXT_PUBLIC_SUPABASE_ATTACHMENTS_BUCKET=lesson-attachments
# NEXT_PUBLIC_MAX_ATTACHMENT_MB=25
