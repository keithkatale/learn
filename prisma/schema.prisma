generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  VIEWER
}

model User {
  id           String                 @id
  name         String?
  /// Creators: real email. Learners (phone auth) may be null after migration, or a phone-derived placeholder.
  email        String?                @unique
  /// Learners: E.164; creators using Supabase email auth may omit
  phone        String?                @unique
  /// Bcrypt hash for learner (phone) accounts — null for Supabase-only creators
  passwordHash String?
  role         Role                   @default(VIEWER)
  /// Last time the learner hit the activity beacon while signed in (phone JWT).
  lastSeenAt   DateTime?
  /// Friendly label the studio admin assigns (e.g. student name) for access / analytics lists.
  instructorLabel String?
  enrollment   Enrollment?
  lessonGrants LearningAccessGrant[]
  visitSessions LearnerVisitSession[]
  createdAt    DateTime               @default(now())
}

/// Browsing session for time-on-platform (30 min idle closes a session).
model LearnerVisitSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt        DateTime  @default(now())
  lastActivityAt   DateTime  @default(now())
  endedAt          DateTime?
  durationSeconds  Int?

  @@index([userId])
  @@index([lastActivityAt])
}

model Class {
  id       String    @id @default(uuid())
  name     String
  subjects Subject[]
  topics   Topic[]
}

model Subject {
  id      String   @id @default(uuid())
  name    String   @unique
  classes Class[]
  topics  Topic[]
}

model Topic {
  id        String    @id @default(uuid())
  name      String
  /// Chapter index within this subject (1 = first chapter added, etc.)
  sortOrder Int       @default(0)
  subjectId String
  classId   String
  subject   Subject   @relation(fields: [subjectId], references: [id])
  class     Class     @relation(fields: [classId], references: [id])
  lessons   Lesson[]
}

model Lesson {
  id           String                @id @default(uuid())
  title        String
  description  String?
  videoUrl     String
  /// JSON array: [{ path, label, mime? }] — paths in Storage bucket `lesson-attachments`
  attachments  Json?
  published    Boolean               @default(true)
  sortOrder    Int                   @default(0)
  topicId      String
  topic        Topic                 @relation(fields: [topicId], references: [id])
  accessGrants LearningAccessGrant[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

/// Time-bound access to a single lesson (partial enrollment).
model LearningAccessGrant {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
